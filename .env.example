# 主Bot Token（管理Bot，用于用户注册/管理自己的Bot）
BOT_TOKEN=你的主Bot_Token

# 管理员 Telegram ID（逗号分隔，可查看平台统计）
ADMIN_IDS=123456789

# 每个用户最多添加的Bot数量（默认1）
MAX_BOTS_PER_USER=1

# 代码前缀（留空则使用 Bot 用户名）
CODE_PREFIX=

# 用户访问模式：默认黑名单模式（blacklist）
# 黑名单用户将被禁止使用主Bot的所有功能
# 管理员使用 /blacklist 命令管理黑名单
# - /blacklist add <用户ID> [原因]  添加到黑名单
# - /blacklist del <用户ID>         从黑名单移除
# - /blacklist list                 查看黑名单
# - /blacklist check <用户ID>       检查用户状态
